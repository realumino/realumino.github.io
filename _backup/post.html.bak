---
layout: default
---

<article>
  <a href="{{ site.url }}/" class="back-link">← 返回首页</a>

  <header class="post-header">
    <h1>{{ page.title }}</h1>
    <div class="post-meta">
      <time datetime="{{ page.date | date: '%Y-%m-%d' }}">{{ page.date | date: '%Y年%-m月%-d日' }}</time>
      {% if page.tags %}
      <span>·</span>
      <span class="tags">
        {% for tag in page.tags %}
        <a class="tag" href="{{ site.url }}/tags#{{ tag | slugify }}">{{ tag }}</a>
        {% endfor %}
      </span>
      {% endif %}
      {% if page.lang and page.lang != "zh" %}
      <span class="post-lang-badge">[{{ page.lang }}]</span>
      {% endif %}
    </div>
  </header>

  <div class="post-content">
    {{ content }}
  </div>
</article>

{% if page.previous.url or page.next.url %}
<nav class="post-nav">
  <span>
    {% if page.previous.url %}
    <a href="{{ page.previous.url }}">← {{ page.previous.title }}</a>
    {% endif %}
  </span>
  <span>
    {% if page.next.url %}
    <a href="{{ page.next.url }}">{{ page.next.title }} →</a>
    {% endif %}
  </span>
</nav>
{% endif %}
